rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlayer(roomData) {
      return isAuthenticated() && 
             (
               (roomData.players.size() > 0 && roomData.players[0].uid == request.auth.uid) || 
               (roomData.players.size() > 1 && roomData.players[1].uid == request.auth.uid) ||
               (roomData.players.size() > 2 && roomData.players[2].uid == request.auth.uid) ||
               (roomData.players.size() > 3 && roomData.players[3].uid == request.auth.uid)
             );
    }

    function isValidRoom(data) {
      return data.status in ['waiting', 'playing', 'finished'] &&
             data.players is list &&
             data.players.size() >= 1 &&
             data.players.size() <= 4 &&
             data.maxPlayers in [2, 4];
    }

    match /rooms/{roomId} {
      
      allow create: if isAuthenticated() && 
                      isValidRoom(request.resource.data) &&
                      request.resource.data.players[0].uid == request.auth.uid;
      
      allow read: if isAuthenticated() && (resource.data.status == 'waiting' || isPlayer(resource.data));
      
      allow update: if isAuthenticated() && (
                      (resource.data.status == 'waiting' && 
                       resource.data.players.size() < resource.data.maxPlayers &&
                       request.resource.data.players.size() <= resource.data.maxPlayers &&
                       request.resource.data.players.size() <= 4) ||
                       isPlayer(resource.data)
                    );

      match /hands/{userId} {
        allow read: if isAuthenticated() && (
          request.auth.uid == userId || 
          (
            exists(/databases/$(database)/documents/rooms/$(roomId)) &&
            isPlayer(get(/databases/$(database)/documents/rooms/$(roomId)).data)
          )
        );
        
        allow write: if isAuthenticated() && (
          request.auth.uid == userId || 
          (
            exists(/databases/$(database)/documents/rooms/$(roomId)) &&
            isPlayer(get(/databases/$(database)/documents/rooms/$(roomId)).data)
          )
        );
      }
    }
  }
}
